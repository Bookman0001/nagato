{
  "name": "sirius-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "run-p dev:*",
    "dev:next": "next dev",
    "dev:path": "pathpida --enableStatic --ignorePath .gitignore --watch",
    "build": "pathpida --enableStatic --ignorePath .gitignore && next build",
    "lint": "eslint './**/*.ts{,x}'",
    "lint:fix": "eslint './**/*.ts{,x}' --fix",
    "prettier": "prettier --check ./**/*.{ts,tsx}",
    "format": "prettier --write ./**/*.{ts,tsx}",
    "tsc": "tsc --noEmit",
    "knip": "knip --config knip.json --exclude devDependencies,unlisted",
    "test": "vitest run"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@vercel/speed-insights": "2.0.0",
    "dayjs": "1.11.21",
    "next": "16.2.7",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.77.0",
    "sanitize-html": "2.17.4",
    "swr": "2.4.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@eslint/compat": "2.1.0",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@next/eslint-plugin-next": "16.2.7",
    "@tailwindcss/postcss": "4.3.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/react-hooks": "8.0.1",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.0",
    "@types/react": "19.2.16",
    "@types/react-test-renderer": "19.1.0",
    "@types/sanitize-html": "2.16.1",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "@vitest/eslint-plugin": "1.6.19",
    "autoprefixer": "10.5.0",
    "babel-loader": "10.1.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.7",
    "eslint-config-prettier": "10.1.8",
    "eslint-config-standard": "17.1.0",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "knip": "6.15.0",
    "lefthook": "2.1.9",
    "mockdate": "3.0.5",
    "msw": "2.14.6",
    "next-router-mock": "1.0.5",
    "next-test-api-route-handler": "5.0.5",
    "npm-run-all2": "9.0.1",
    "pathpida": "0.26.1",
    "postcss": "8.5.15",
    "prettier": "3.8.3",
    "react-test-renderer": "19.2.7",
    "tailwindcss": "4.3.0",
    "tailwindcss-cli": "0.1.2",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "undici": "8.3.0",
    "vitest": "4.1.8"
  },
  "packageManager": "pnpm@10.34.1"
}
