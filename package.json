{
  "name": "sirius-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "run-p dev:*",
    "dev:next": "next dev",
    "dev:path": "pathpida --enableStatic --ignorePath .gitignore --watch",
    "build": "pathpida --enableStatic --ignorePath .gitignore && next build",
    "lint": "eslint './**/*.ts{,x}'",
    "lint:fix": "eslint './**/*.ts{,x}' --fix",
    "prettier": "prettier --check ./**/*.{ts,tsx}",
    "format": "prettier --write ./**/*.{ts,tsx}",
    "compiler-check": "tsc --noEmit",
    "knip": "knip --config knip.json --exclude devDependencies,unlisted",
    "test": "vitest run"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "./**/*.{ts,tsx}": [
      "eslint",
      "prettier"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@vercel/speed-insights": "2.0.0",
    "dayjs": "1.11.20",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.73.1",
    "sanitize-html": "2.17.3",
    "styled-components": "6.4.1",
    "swr": "2.4.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@eslint/compat": "2.0.5",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@next/eslint-plugin-next": "16.2.4",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/react-hooks": "8.0.1",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-test-renderer": "19.1.0",
    "@types/sanitize-html": "2.16.1",
    "@types/styled-components": "5.1.36",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "@vitest/eslint-plugin": "1.6.16",
    "babel-loader": "10.1.1",
    "babel-plugin-styled-components": "2.1.4",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-config-standard": "17.1.0",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.5.0",
    "jsdom": "29.0.2",
    "knip": "6.7.0",
    "lint-staged": "16.4.0",
    "mockdate": "3.0.5",
    "msw": "2.13.6",
    "next-router-mock": "1.0.5",
    "next-test-api-route-handler": "5.0.4",
    "npm-run-all2": "8.0.4",
    "pathpida": "0.26.1",
    "prettier": "3.8.3",
    "react-test-renderer": "19.2.5",
    "simple-git-hooks": "2.13.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "undici": "8.1.0",
    "vitest": "4.1.5"
  }
}
